<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Energy Efficiency Calculator</title>
<style>
body{font-family:Arial,sans-serif;max-width:900px;margin:auto;padding:30px;color:#303544}
h1,h2{color:#344054}
label{display:block;margin-top:15px;font-size:14px}
input,select,button{width:100%;padding:10px;margin-top:5px;border-radius:8px;border:1px solid #ddd}
button{background:#4CAF50;color:white;font-weight:bold;cursor:pointer}
.section{margin-bottom:30px}
.hidden{display:none}
.result{background:#eef9ee;padding:15px;border-radius:10px}
canvas{margin-top:20px}
</style>
</head>

<body>

<h1>Energy Efficiency Calculator</h1>
<p>An easy, user-friendly application created by Zain Ahmad</p>

<div class="section">
<h2>General Information About Your Home</h2>

<label>Enter square footage of the house</label>
<input id="area" type="number" value="0">

<label>Average monthly energy consumption (kWh)</label>
<input id="kwh" type="number" value="0">

<label>Average monthly energy cost ($)</label>
<input id="cost" type="number" value="0">

<label>High efficiency windows installed in last 15 years?</label>
<select id="windows"><option>Yes</option><option>No</option></select>

<label>Number of conventional light bulbs</label>
<input id="bulbs" type="number" value="0">

<label>Number of LED light bulbs</label>
<input id="led" type="number" value="0">

<label>Learning thermostat?</label>
<select id="thermostat"><option>Yes</option><option>No</option></select>

<label>Electric heating?</label>
<select id="heating"><option>Yes</option><option>No</option></select>

<label>Electric air conditioning?</label>
<select id="ac"><option>Yes</option><option>No</option></select>

<label>Electric hot water?</label>
<select id="water"><option>Yes</option><option>No</option></select>

</div>


<div class="section">
<h2>Energy Efficient Appliances</h2>

<label>Oven/Stovetop Energy Star?</label>
<select id="oven"><option>Yes</option><option>No</option></select>

<label>Washer Energy Star?</label>
<select id="washer"><option>Yes</option><option>No</option></select>

<label>Dryer Energy Star?</label>
<select id="dryer"><option>Yes</option><option>No</option></select>

<label>Refrigerator Energy Star?</label>
<select id="fridge"><option>Yes</option><option>No</option></select>

</div>


<div class="section">
<h2>Detailed Appliance Information</h2>

<label>Oven watt mode</label>
<select id="ovenMode"><option>Average</option><option>Actual</option></select>
<input id="ovenWatts" placeholder="Oven watts">

<label>Oven usage mode</label>
<select id="ovenUsage"><option>Average</option><option>Actual</option></select>
<input id="ovenHours" placeholder="Hours/month">

<label>Washer watt mode</label>
<select id="washerMode"><option>Average</option><option>Actual</option></select>
<input id="washerWatts" placeholder="Washer watts">

<label>Washer usage mode</label>
<select id="washerUsage"><option>Average</option><option>Actual</option></select>
<input id="washerHours" placeholder="Hours/month">

<label>Dryer watt mode</label>
<select id="dryerMode"><option>Average</option><option>Actual</option></select>
<input id="dryerWatts" placeholder="Dryer watts">

<label>Dryer usage mode</label>
<select id="dryerUsage"><option>Average</option><option>Actual</option></select>
<input id="dryerHours" placeholder="Hours/month">

<label>Refrigerator watt mode</label>
<select id="fridgeMode"><option>Average</option><option>Actual</option></select>
<input id="fridgeWatts" placeholder="Refrigerator watts">

<label>Refrigerator usage mode</label>
<select id="fridgeUsage"><option>Average</option><option>Actual</option></select>
<input id="fridgeHours" placeholder="Hours/month">


<h2>Additional Questions</h2>

<label>Own electric vehicle?</label>
<select id="ev"><option>Yes</option><option>No</option></select>

<button onclick="calculate()">Calculate Results</button>

</div>


<div id="output" class="hidden">
<h2>Your Individualized Report</h2>
<div class="result" id="summary"></div>

<h3>Savings Breakdown</h3>
<canvas id="bar"></canvas>

<h3>Money Saved vs Energy Saved</h3>
<canvas id="scatter"></canvas>

<div id="details"></div>

<button onclick="pdf()">Download PDF Report</button>

</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script>

let report={};

function val(id){
return Number(document.getElementById(id).value)||0;
}

function appliance(powerMode,power,hoursMode,hours,defaultPower,defaultHours){

let watts = powerMode==="Actual" ? power : defaultPower;
let hrs = hoursMode==="Actual" ? hours : defaultHours;

return watts*hrs/1000*0.3;

}


function calculate(){

const kwh=val("kwh");

const energyStar=0.3;
const thermostatSavings=0.11;
const windowsSavings=0.12;
const moneyConverter=0.1798;
const tesla=153.33;


let items={

"Bulbs":val("bulbs")*52*1.6*30/1000,

"Thermostat":
document.getElementById("thermostat").value==="No"
?kwh*thermostatSavings:0,

"Windows":
document.getElementById("windows").value==="No"
?kwh*windowsSavings:0,

"Washer":
document.getElementById("washer").value==="No"
?appliance(
washerMode.value,val("washerWatts"),
washerUsage.value,val("washerHours"),
2000,24):0,

"Dryer":
document.getElementById("dryer").value==="No"
?appliance(
dryerMode.value,val("dryerWatts"),
dryerUsage.value,val("dryerHours"),
2800,30):0,

"Oven/Stovetop":
document.getElementById("oven").value==="No"
?appliance(
ovenMode.value,val("ovenWatts"),
ovenUsage.value,val("ovenHours"),
2350,25):0,

"Refrigerator":
document.getElementById("fridge").value==="No"
?appliance(
fridgeMode.value,val("fridgeWatts"),
fridgeUsage.value,val("fridgeHours"),
2000,24):0

};


let total=Object.values(items).reduce((a,b)=>a+b,0);

report={items,total,money:total*moneyConverter};


output.classList.remove("hidden");


summary.innerHTML=
`You have potential to save <b>${total.toFixed(2)} kWh</b> and <b>$${(total*moneyConverter).toFixed(2)}</b> per month!`;



new Chart(bar,{
type:"bar",
data:{
labels:Object.keys(items),
datasets:[{
label:"Potential Monthly Savings (kWh)",
data:Object.values(items)
}]
}
});


new Chart(scatter,{
type:"bubble",
data:{
labels:Object.keys(items),
datasets:[{
label:"Energy Savings",
data:Object.keys(items).map((x,i)=>({
x:i,
y:items[x],
r:items[x]*2
}))
}]
}
});


details.innerHTML="";

for(let x in items){

if(items[x]>0){

details.innerHTML+=
`<p>${x}: saves ${items[x].toFixed(2)} kWh → $${(items[x]*moneyConverter).toFixed(2)}</p>`;

}

}

if(total>=tesla){

details.innerHTML+=
"<p><b>You can save enough energy monthly to charge an electric vehicle!</b></p>";

}

}



function pdf(){

const {jsPDF}=window.jspdf;

let doc=new jsPDF();

doc.text("Energy Efficiency Report",20,20);

doc.text(
`Potential savings: ${report.total.toFixed(2)} kWh/month`,
20,40);

doc.text(
`Money saved: $${report.money.toFixed(2)}/month`,
20,60);


let y=80;

for(let x in report.items){

doc.text(
`${x}: ${report.items[x].toFixed(2)} kWh`,
20,y);

y+=10;

}

doc.save("energy_efficiency_report.pdf");

}


</script>

</body>
</html>
